# Site root (no trailing slash). Use your custom domain when ready.
# NEXT_PUBLIC_SITE_URL=your_domain_url

# Google Search Console HTML tag verification content value
# NEXT_PUBLIC_GSC_VERIFICATION=your-verification-token

# Calendly booking link (shows Book a call button when set)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/30min
